{
  "name": "oak-longevity-mcp-server",
  "version": "0.1.0",
  "mcpName": "io.github.Goingparabolic/oak-longevity-mcp-server",
  "description": "Model Context Protocol (MCP) server for longevity & metabolic medicine — medication catalog, evidence-based dosing protocols, contraindication screening, drug-interaction checks, required baseline labs, ongoing monitoring plans, FDA/compounding regulatory status, and patient-intake pathway suggestions across 35 compounds (GLP-1s, peptides, hormones, NAD+/rapamycin/metformin, and more).",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "longevity-medicine",
    "metabolic-health",
    "peptide-therapy",
    "hormone-optimization",
    "glp-1",
    "semaglutide",
    "tirzepatide",
    "rapamycin",
    "nad",
    "contraindications",
    "drug-interactions",
    "compounding",
    "503a",
    "claude",
    "telemedicine",
    "clinical-decision-support"
  ],
  "homepage": "https://www.oaklongevity.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Goingparabolic/oak-longevity-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Goingparabolic/oak-longevity-mcp-server/issues"
  },
  "license": "MIT",
  "author": "Keith Schmidt, MD",
  "type": "module",
  "bin": {
    "oak-longevity-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "smoke": "node scripts/smoke-test.mjs",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
